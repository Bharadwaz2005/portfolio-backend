# ===== PORTFOLIO ENV =====
# Copy this to .env and fill in your values

# Server
PORT=3000
NODE_ENV=development

# Database (MySQL)
MYSQLHOST=localhost
MYSQLPORT=3306
MYSQLUSER=root
MYSQLPASSWORD=pass123
MYSQLDATABASE=userDetails

# Security
ALLOWED_ORIGIN=http://localhost:3000

# === FOR PRODUCTION (Render / Railway / VPS) ===
# NODE_ENV=production
# MYSQLHOST=your-db-host
# MYSQLPORT=your-db-port
# MYSQLUSER=your-db-user
# MYSQLPASSWORD=your-secure-password
# MYSQLDATABASE=userDetails
# ALLOWED_ORIGIN=https://your-domain.com